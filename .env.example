# ============================================
# OpenAI API 配置（用于 LLM 内容分析）
# ============================================
# 支持 OpenAI 官方 API 或兼容的第三方服务（如 Azure OpenAI、本地部署的模型）
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY="sk-your-api-key-here"
OPENAI_MODEL="gpt-4o-mini"

# ============================================
# 定时任务配置
ENABLE_SCHEDULER=true  # 是否启用定时任务
SCHEDULER_CHECK_INTERVAL="* * * * *"  # 检查间隔（默认每分钟）

# ============================================
# 数据库配置
# ============================================
DATABASE_URL="./data/engine_vec.db"

# ============================================
# 服务器配置
# ============================================
PORT=3001
NODE_ENV="development"

# ============================================
# 文件存储
# ============================================
STORAGE_PATH="./storage"
MAX_VIDEO_SIZE_MB=500

# ============================================
# Redis 配置（任务队列）
# ============================================
REDIS_HOST="localhost"
REDIS_PORT=6379
# REDIS_PASSWORD=""  # 生产环境需要设置

# ============================================
# 前端配置（保留用于 AI Studio 兼容）
# ============================================
# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"
